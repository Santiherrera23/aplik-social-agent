# =============================================
# APLIK SOCIAL AGENT — Variables de entorno
# =============================================
# Copia este archivo como .env y llena con tus valores reales
# En Railway, se configuran en Settings → Variables

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (GPT Image 1.5)
OPENAI_API_KEY=sk-proj-xxxxx

# Publer
PUBLER_API_KEY=xxxxx
PUBLER_WORKSPACE_ID=xxxxx

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxx

# IDs de cuentas sociales en Publer (obtener con GET /api/v1/accounts)
# Aplik
PUBLER_ACCOUNT_INSTAGRAM_APLIK=
PUBLER_ACCOUNT_TIKTOK_APLIK=
PUBLER_ACCOUNT_X_APLIK=

# Segundo negocio (configurar cuando esté listo)
# PUBLER_ACCOUNT_INSTAGRAM_BIZ2=
# PUBLER_ACCOUNT_TIKTOK_BIZ2=
# PUBLER_ACCOUNT_X_BIZ2=

# Slack webhook para notificaciones (opcional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx
